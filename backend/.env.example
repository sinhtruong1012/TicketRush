# Copy file này thành .env và điền thông tin của bạn
# cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ticketrush
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT - đặt chuỗi bí mật bất kỳ, càng dài càng tốt
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS - URL của frontend
CORS_ORIGIN=http://localhost:5173

# Virtual Queue
MAX_CONCURRENT_USERS=50
QUEUE_BATCH_SIZE=10

# Seat Lock (phút)
SEAT_LOCK_TIMEOUT_MINUTES=10
